#!/usr/bin/env bash
# mcl-claude — per-project isolated Claude Code launcher.
#
# Computes a stable project key from $PWD's realpath, ensures
# ~/.mcl/projects/<key>/ scaffolding exists, exports MCL_STATE_DIR for
# hooks, and exec's claude with --settings + --plugin-dir pointing at
# the per-project config and the shared MCL library.
#
# Pure passthrough wrapper: all positional args and flags are forwarded
# verbatim to claude. No --mcl-* flags, no admin subcommands.
#
# Since 8.5.0.

set -euo pipefail

MCL_HOME="${MCL_HOME:-$HOME/.mcl}"
MCL_LIB="$MCL_HOME/lib"

if [ ! -d "$MCL_LIB" ]; then
  echo "mcl-claude: MCL library not found at $MCL_LIB" >&2
  echo "  Run install.sh first: curl -sSL <repo>/install.sh | bash" >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "mcl-claude: 'claude' binary not found on PATH" >&2
  echo "  Install Claude Code first: https://docs.claude.com/claude-code" >&2
  exit 1
fi

# ---- Compute project key from realpath of $PWD ----
real_pwd="$(cd "$PWD" && pwd -P)"

# sha1 with cross-platform fallback (macOS: shasum, Linux: sha1sum).
if command -v shasum >/dev/null 2>&1; then
  key="$(printf '%s' "$real_pwd" | shasum -a 1 | awk '{print $1}')"
elif command -v sha1sum >/dev/null 2>&1; then
  key="$(printf '%s' "$real_pwd" | sha1sum | awk '{print $1}')"
else
  echo "mcl-claude: neither shasum nor sha1sum available — cannot compute project key" >&2
  exit 1
fi

proj_dir="$MCL_HOME/projects/$key"
state_dir="$proj_dir/state"
settings_file="$proj_dir/settings.json"

# ---- Auto-init on first run ----
if [ ! -d "$proj_dir" ]; then
  mkdir -p "$state_dir"

  mcl_version="$(cat "$MCL_LIB/VERSION" 2>/dev/null || echo unknown)"
  created_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # settings.json: hook command paths point at shared MCL_LIB.
  # Variables expand here (heredoc unquoted), so absolute paths are
  # baked in at init time. Re-init (mcl-claude --mcl-reinit) is not
  # implemented; user can rm -rf "$proj_dir" to force re-init.
  cat > "$settings_file" <<JSON
{
  "hooks": {
    "UserPromptSubmit": [
      {"matcher": "", "hooks": [{"type": "command", "command": "$MCL_LIB/hooks/mcl-activate.sh"}]}
    ],
    "Stop": [
      {"matcher": "", "hooks": [{"type": "command", "command": "$MCL_LIB/hooks/mcl-stop.sh"}]}
    ],
    "PreToolUse": [
      {"matcher": "", "hooks": [{"type": "command", "command": "$MCL_LIB/hooks/mcl-pre-tool.sh"}]}
    ],
    "PostToolUse": [
      {"matcher": "", "hooks": [{"type": "command", "command": "$MCL_LIB/hooks/mcl-post-tool.sh"}]}
    ]
  }
}
JSON

  cat > "$proj_dir/meta.json" <<JSON
{
  "key": "$key",
  "path": "$real_pwd",
  "created_at": "$created_at",
  "mcl_version": "$mcl_version"
}
JSON
fi

# ---- Export env for hooks + Claude Code ----
export MCL_HOME
export MCL_STATE_DIR="$state_dir"
export MCL_PROJECT_KEY="$key"

# ---- Single-session-per-project lock (since 8.18.0) ----
# A second mcl-claude invocation against the same project would share
# state.json, audit.log, and the rotating skill-token — concurrent
# writes are not coordinated and the token rotation race-condition
# would invalidate the active session's token mid-turn. Lock prevents
# that footgun. Cleared on normal exit, on Ctrl-C, and on stale-PID
# detection if a previous wrapper crashed without cleaning up.
LOCK_FILE="$state_dir/session.lock"

if [ -f "$LOCK_FILE" ]; then
  existing_pid="$(cat "$LOCK_FILE" 2>/dev/null | tr -d '[:space:]')"
  if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
    echo "mcl-claude: MCL session already active for this project (PID $existing_pid)." >&2
    echo "  Project: $real_pwd" >&2
    echo "  Lock:    $LOCK_FILE" >&2
    echo "  Exit the other terminal first, or:" >&2
    echo "    kill $existing_pid && rm $LOCK_FILE" >&2
    exit 1
  fi
  # Stale lock — owning process is gone. Reclaim silently.
  rm -f "$LOCK_FILE" 2>/dev/null || true
fi

# Acquire the lock with our own PID. mode 0600 (umask 077) — only the
# owning user reads/writes; subprocess inheritance does not change this.
(umask 077 && printf '%s' "$$" > "$LOCK_FILE")

# Cleanup runs on normal exit AND on signals (HUP/INT/TERM). We only
# remove the lock if it still names OUR pid — defensive against the
# stale-recovery path racing a second wrapper that already took over.
_mcl_unlock() {
  if [ -f "$LOCK_FILE" ]; then
    local owner
    owner="$(cat "$LOCK_FILE" 2>/dev/null | tr -d '[:space:]')"
    [ "$owner" = "$$" ] && rm -f "$LOCK_FILE" 2>/dev/null || true
  fi
}
trap _mcl_unlock EXIT
trap 'exit 130' INT
trap 'exit 143' TERM HUP

# ---- Run claude with isolated config ----
# Cannot `exec` because that replaces the wrapper process and skips the
# EXIT trap. Spawn claude as a child, wait, then propagate the exit
# code. The lock is released by _mcl_unlock once we fall off the end.
claude \
  --settings "$settings_file" \
  --plugin-dir "$MCL_LIB" \
  "$@"
exit $?
