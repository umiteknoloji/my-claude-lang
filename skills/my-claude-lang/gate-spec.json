{
  "version": "13.0.9",
  "_comment": "Universal deterministic gate spec. Hook reads this to decide phase completeness AND allowed tools per phase (since v13.0.9). Model emits per-item / per-section / scan-rescan / triple audits ONLY; *-complete and phase_transition are hook-emitted via lib/mcl-gate.sh.",
  "_global_always_allowed_tools": ["Read", "Glob", "Grep", "LS", "WebFetch", "WebSearch", "Task", "Skill", "Bash"],
  "_comment_allowlist": "allowed_tools per phase = mutating tools (Write/Edit/MultiEdit/NotebookEdit/AskUserQuestion/TodoWrite). Read-only + Bash are global-always-allowed (Bash filtered separately by audit-emit pattern in pre-tool). denied_paths blocks specific paths even when tool is allowed.",
  "_comment_phase_marker": "phase_marker_audits: audit names whose presence indicates this phase is the active or current target. Used by checkpoint ritual (pre-tool) to detect phase mismatch.",
  "phases": {
    "1":  {"type": "single",    "required_audits": ["summary-confirm-approve"], "allowed_tools": ["AskUserQuestion"], "phase_marker_audits": ["asama-1-question", "summary-confirm-approve"]},
